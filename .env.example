# Database
DATABASE_URL=postgres://docs:docs@localhost:5432/openaec_docs

# Server
HOST=0.0.0.0
PORT=3000

# Authentication (set AUTH_ENABLED=true in production)
AUTH_ENABLED=false
OIDC_ISSUER_URL=https://auth.open-aec.com/application/o/openaec-docs/
OIDC_CLIENT_ID=openaec-docs
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:3000/auth/callback
JWT_SECRET=dev-secret-change-me-in-production-32chars!
FRONTEND_URL=http://localhost:5173

# Nextcloud cloud storage (opt-in, all three required)
# NEXTCLOUD_URL=http://nc-3bm:80
# NEXTCLOUD_SERVICE_USER=openaec-service
# NEXTCLOUD_SERVICE_PASS=

# Tenant config file path
TENANTS_CONFIG=/etc/openaec/tenants.json

# Integration URLs (internal Docker network)
BIM_VALIDATOR_URL=http://bim-validator:8000
BCF_PLATFORM_URL=http://bcf-server:3000
